-- CTE для очищення кумулятивних даних від дублів
-- Залишаємо лише один найновіший рядок для кожної унікальної комбінації оголошення та дати
WITH deduped_ads AS (
  SELECT
    source,
    spend,
    registrations
  FROM (
    SELECT
      source,
      spend,
      registrations,
      -- ROW_NUMBER відсікає старі логи, сортуючи записи від найновішого до найстарішого
      -- Партиціонуємо по ad_id та date, бо кумулятивність оновлюється в межах одного дня для кожного оголошення
      ROW_NUMBER() OVER (
        PARTITION BY ad_id, date 
        ORDER BY timestamp DESC
      ) AS rn
    FROM `skelar-task-1-496711.marketing_ads_raw.marketing_ads_raw`
  )
  -- Фільтр rn = 1 залишає тільки актуальний стан даних за кожен день
  WHERE rn = 1
),

-- CTE для розрахунку загальних витрат, реєстрацій та підсумкового CAC по кожному каналу
channel_cac AS (
  SELECT
    source,
    SUM(spend) AS total_spend,
    SUM(registrations) AS total_registrations,
    -- NULLIF захищає від помилки ділення на нуль, якщо канал не приніс реєстрацій
    SUM(spend) / NULLIF(SUM(registrations), 0) AS cac
  FROM deduped_ads
  GROUP BY 1
)

SELECT
  source,
  ROUND(cac, 2) AS cac,
  -- LOWER(source) приводить назву каналу до нижнього регістру, щоб уникнути помилок через різний регістр букв
  CASE 
    WHEN LOWER(source) = 'tiktok' THEN 8.50
    WHEN LOWER(source) = 'meta' THEN 6.20
    WHEN LOWER(source) = 'google' THEN 12.40
    ELSE 0 
  END AS ltv,
  -- Розраховуємо співвідношення LTV/CAC (коефіцієнт окупності)
  -- NULLIF захищає від ділення на нуль, якщо витрати (або CAC) дорівнюють 0
  ROUND(
    CASE 
      WHEN LOWER(source) = 'tiktok' THEN 8.50
      WHEN LOWER(source) = 'meta' THEN 6.20
      WHEN LOWER(source) = 'google' THEN 12.40
      ELSE 0 
    END / NULLIF(cac, 0), 
    2
  ) AS ltv_to_cac
FROM channel_cac
-- Сортуємо від найвищого коефіцієнта окупності до найнижчого
ORDER BY ltv_to_cac DESC
